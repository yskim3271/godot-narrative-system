description = "지하실 쥐 처치"
target_count = 5

[sub_resource type="Resource" id="Resource_8r0l4"]
script = ExtResource("6_kmg6b")
id = "rat_hunt"
title = "쥐 사냥"
description = "경비병의 부탁: 지하실에 들끓는 쥐를 정리하자."
objectives = Array[ExtResource("7_fo4aq")]([SubResource("Resource_nesgo")])
prerequisites = PackedStringArray()
rewards = "gold += 100
alert(\"ui.alert.reward_gold\")"

