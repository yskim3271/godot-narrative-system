[sub_resource type="Resource" id="Resource_8vncj"]
script = ExtResource("1_sulo8")
id = "player"
display_name = "나"
portrait = SubResource("GradientTexture2D_lmv82")

[sub_resource type="Resource" id="Resource_42r8o"]
script = ExtResource("3_vs55d")
id = "g_return"
speaker_id = "guard"
text = "또 자네군. 무슨 일이지?"
conditions = "has_seen(\"guard_talk\", \"g_first\")"
next_node_id = "g_first"

[sub_resource type="Resource" id="Resource_lq8xv"]
script = ExtResource("3_vs55d")
id = "g_first"
speaker_id = "guard"
text = "처음 보는 얼굴이군. 이 마을엔 무슨 일로 왔나?"
conditions = "not has_seen(\"guard_talk\", \"g_first\")"
sequencer_commands = "set_expression(\"guard\", \"angry\")"
next_node_id = "g_menu"

[sub_resource type="Resource" id="Resource_gxiqn"]
script = ExtResource("4_1dswq")
id = "c_quest"
text = "일거리가 있나?"
condition = "quest_state(\"rat_hunt\") == \"inactive\""
target_node_id = "q_give"

[sub_resource type="Resource" id="Resource_ryf5l"]
script = ExtResource("4_1dswq")
id = "c_progress"
text = "쥐는 잡는 중이야."
condition = "is_quest_active(\"rat_hunt\") and objective_count(\"rat_hunt\", \"kill_rats\") < 5"
target_node_id = "q_progress"

[sub_resource type="Resource" id="Resource_iyrwl"]
script = ExtResource("4_1dswq")
id = "c_done"
text = "쥐를 모두 처리했네."
condition = "is_quest_active(\"rat_hunt\") and objective_count(\"rat_hunt\", \"kill_rats\") >= 5"
target_node_id = "q_done"

[sub_resource type="Resource" id="Resource_agese"]
script = ExtResource("4_1dswq")
id = "c_bribe"
text = "통행료를 내겠네. (50골드)"
condition = "gold >= 50"
show_disabled = true
actions = "gold -= 50
met_guard = true"
target_node_id = "q_bribe"

[sub_resource type="Resource" id="Resource_8cf14"]
script = ExtResource("4_1dswq")
id = "c_bye"
text = "아무것도 아닐세."

[sub_resource type="Resource" id="Resource_hbcdb"]
script = ExtResource("3_vs55d")
id = "g_menu"
speaker_id = "guard"
text = "용건을 말해보게."
sequencer_commands = "set_expression(\"guard\", \"\")"
choices = Array[ExtResource("4_1dswq")]([SubResource("Resource_gxiqn"), SubResource("Resource_ryf5l"), SubResource("Resource_iyrwl"), SubResource("Resource_agese"), SubResource("Resource_8cf14")])

[sub_resource type="Resource" id="Resource_cfwtd"]
script = ExtResource("3_vs55d")
id = "q_give"
speaker_id = "guard"
text = "지하실에 쥐가 들끓고 있네. 다섯 마리만 잡아주게."
actions = "start_quest(\"rat_hunt\")
alert(\"ui.alert.quest_started\")"
sequencer_commands = "set_expression(\"guard\", \"happy\")
play_animation(\"guard\", \"wave\")
wait(0.5)
focus_camera(\"guard\", 0.4)
emit_signal(\"quest_given\")
wait(0.6)
move_camera(0, 0, 0.4)"

[sub_resource type="Resource" id="Resource_b7wah"]
script = ExtResource("3_vs55d")
id = "q_progress"
speaker_id = "guard"
text = "서둘러 주게. 쥐들이 곡식을 다 먹어치우고 있어."

[sub_resource type="Resource" id="Resource_j5e4g"]
script = ExtResource("3_vs55d")
id = "q_done"
speaker_id = "guard"
text = "훌륭하군! 약속한 보수일세."
actions = "complete_quest(\"rat_hunt\")
alert(\"ui.alert.quest_done\")"
sequencer_commands = "set_expression(\"guard\", \"happy\")
play_animation(\"guard\", \"wave\")"

[sub_resource type="Resource" id="Resource_442bk"]
script = ExtResource("3_vs55d")
id = "q_bribe"
speaker_id = "guard"
text = "흠… 좋아, 지나가게."
sequencer_commands = "set_expression(\"guard\", \"happy\")"

[sub_resource type="Resource" id="Resource_fqbr7"]
script = ExtResource("2_l11le")
id = "guard_talk"
title = "경비병 대화"
start_node_id = "g_return"
nodes = Array[ExtResource("3_vs55d")]([SubResource("Resource_42r8o"), SubResource("Resource_lq8xv"), SubResource("Resource_hbcdb"), SubResource("Resource_cfwtd"), SubResource("Resource_b7wah"), SubResource("Resource_j5e4g"), SubResource("Resource_442bk")])

