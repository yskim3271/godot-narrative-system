; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="Narrative System for Godot"
config/description="All-in-one narrative system addon for Godot 4: branching dialogue, quests, save/load, localization, barks, alerts, and a cutscene sequencer."
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[editor_plugins]

enabled=PackedStringArray("res://addons/narrative_system/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
